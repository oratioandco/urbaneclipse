# Cesium Ion access token — create at https://ion.cesium.com/tokens/ (free Community tier).
# Copy this file to .env and paste your token. .env is gitignored — NEVER commit it.
PUBLIC_CESIUM_ION_TOKEN=

# --- 3D tileset source ---------------------------------------------------------
# Where the browser fetches the Berlin 3D Tiles from. Defaults to the committed
# 20-tile subset at /berlin-core/tileset.json when unset. Point this at the R2
# public/custom-domain URL once the full tileset is uploaded, e.g.
#   https://tiles.example.com/berlin-full/tileset.json
PUBLIC_TILESET_URL=

# --- Tile hosting ---------------------------------------------------------------
# The full Berlin tileset is NOT uploaded from here. It is synced to the Hetzner host
# over Tailscale and served from a Docker volume at the same origin as the app:
#   scripts/sync_tiles_hetzner.sh
# The deployed URL is set by the Dockerfile (ARG PUBLIC_TILESET_URL), not by env here.
